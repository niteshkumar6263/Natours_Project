header.header
  nav.nav.nav--tours
    a.nav__el(href='/') All tours
  .header__logo
    img(src='/img/logo-white.png' alt='Natours logo')
  nav.nav.nav--user
    form.nav__search(action='/' method='GET')
      button.nav__search-btn(type='submit' aria-label='Search tours')
        svg
          use(xlink:href='/img/icons.svg#icon-search')
      input.nav__search-input(
        type='text'
        name='search'
        placeholder='Search tours'
        value=searchQuery || ''
      )
    if user
      a.nav__el.nav__el--logout(href='/api/v1/users/logout') Log out
      a.nav__el(href='/me')
        img.nav__user-img(src=user.photo, alt=`Photo of ${user.name}`)
        span= user.name.split(' ')[0]
    else
      a.nav__el(href='/login') Log in
      a.nav__el.nav__el--cta(href='/signup') Sign up
